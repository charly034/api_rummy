# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Identidad de la API ────────────────────────────────────────
API_NAME=Rummys
API_VERSION=v1

# ── CORS ──────────────────────────────────────────────────────
# En desarrollo apunta al Vite dev server.
# En producción usá el dominio real: https://tudominio.com
CORS_ORIGIN=http://localhost:5173

# ── Base de datos PostgreSQL ───────────────────────────────────
# Opción A: connection string completa (recomendada en VPS)
DATABASE_URL=postgresql://usuario:password@localhost:5432/rummys

# Opción B: variables individuales (se usan si DATABASE_URL está vacía)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rummys
DB_USER=usuario
DB_PASSWORD=password

# ── SSL de base de datos ───────────────────────────────────────
# En VPS local con PostgreSQL propio: false
# En bases de datos cloud (Railway, Supabase, Neon, etc.): true
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
PGSSLMODE=disable

# ── Pool de conexiones ─────────────────────────────────────────
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
